<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_PROMOTED_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    
    <!-- Need to discover installed apps for app launching -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>
    
    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/Theme.Citros">
        
        <activity
            android:name=".ChatActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="citros"
                    android:host="oauth"
                    android:path="/callback" />
            </intent-filter>
        </activity>

        <activity-alias
            android:name=".LauncherNone"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_none"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_none"
            android:targetActivity=".ChatActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".LauncherTangerine"
            android:enabled="true"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_tangerine"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_tangerine"
            android:targetActivity=".ChatActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".LauncherLemon"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_lemon"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_lemon"
            android:targetActivity=".ChatActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".LauncherLime"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_lime"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_lime"
            android:targetActivity=".ChatActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".LauncherBloodOrange"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_blood_orange"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_blood_orange"
            android:targetActivity=".ChatActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".LauncherGrapefruit"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_grapefruit"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_grapefruit"
            android:targetActivity=".ChatActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        
        <service
            android:name=".CitrosAccessibilityService"
            android:exported="true"
            android:label="Citros Phone Control"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>
        
        <!-- Notification access requires user grant via Settings → Apps → Special access → Notification access.
             This is a runtime system permission, not a manifest permission. -->
        <service
            android:name=".CitrosNotificationListener"
            android:exported="true"
            android:label="Citros Notification Access"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <service
            android:name=".OverlayService"
            android:exported="false"
            android:stopWithTask="false"
            android:foregroundServiceType="specialUse|microphone">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="floating_overlay_mini_chat" />
        </service>
        
    </application>
</manifest>
